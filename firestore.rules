rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── USUARIOS ───
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ─── CITAS ───
    match /appointments/{appointmentId} {
      // Cualquier usuario autenticado puede crear, pero SOLO con status 'pending'
      allow create: if request.auth != null
                    && request.resource.data.status == 'pending';

      // Un usuario solo puede leer sus propias citas; admin lee todas
      allow read: if request.auth != null
                  && (resource.data.userId == request.auth.uid || isAdmin());

      // Solo admin puede modificar o eliminar citas
      allow update, delete: if isAdmin();
    }

    // ─── FRANJAS BLOQUEADAS ───
    match /blocked_slots/{slotId} {
      // Cualquier usuario autenticado puede leer (para ver disponibilidad en calendario)
      allow read: if request.auth != null;
      // Solo admin puede crear, modificar o eliminar bloqueos
      allow write: if isAdmin();
    }

    // ─── AFORO POR FRANJA (datos públicos, sin info de usuarios) ───
    match /slot_occupancy/{slotId} {
      // Cualquier usuario autenticado puede leer (para pintar el calendario)
      allow read: if request.auth != null;
      // Solo admin puede modificar (se actualiza al aprobar/revertir citas)
      allow write: if isAdmin();
    }

    // ─── SERVICIOS ───
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── TESTIMONIOS ───
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // ─── CMS / CONTENIDO DEL SITIO ───
    match /site_content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── ACTIVITY LOGS ───
    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }

    // ─── FUNCIÓN HELPER ───
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
